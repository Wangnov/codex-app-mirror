{
  "name": "codex-app-mirror-dispatcher",
  "main": "src/index.js",
  "compatibility_date": "2026-05-23",
  "workers_dev": false,
  "triggers": {
    "crons": ["7,22,37,52 * * * *"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  // Worker source lives in Wangnov/agents-mirror-kit (workers/github-dispatcher);
  // this file is the per-instance deployment config. Deploy by copying it next
  // to the kit worker's src/ and running `npx wrangler deploy` there.
  // The instance dispatches mirror.yml for codex-app-mirror and agents-cli-mirror.
  "vars": {
    "DISPATCH_TARGETS": "[{\"owner\":\"Wangnov\",\"repo\":\"codex-app-mirror\",\"inputs\":{\"force_release\":\"false\"}},{\"owner\":\"Wangnov\",\"repo\":\"agents-cli-mirror\"}]"
  },
  "secrets": {
    "required": ["GITHUB_TOKEN"]
  }
}
